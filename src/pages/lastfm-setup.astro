---
import Layout from "../layouts/Layout.astro";

const lastfmUsername = Astro.cookies.get("lastfm_username")?.value;
const accessToken = Astro.cookies.get("spotify_access_token")?.value;
if (lastfmUsername || accessToken) return Astro.redirect("/dashboard");
---

<Layout title="Last.fm instellen" description="Hoe je Last.fm koppelt aan Matcher om jouw vinyl matches te zien.">
  <style>
    body {
      display: flex;
      flex-direction: column;
      align-items: center;
      min-height: 100vh;
      overflow-x: hidden;
    }

    #main-content {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 48px 20px;
      width: 100%;
      max-width: 640px;
    }

    .back-link {
      font-family: "Space Mono", monospace;
      font-size: 16px;
      color: rgba(245, 239, 214, 0.5);
      text-decoration: none;
      letter-spacing: 2px;
      text-transform: uppercase;
      align-self: flex-start;
      margin-bottom: 40px;
      transition: color 0.2s;
    }

    .back-link:hover {
      color: rgba(245, 239, 214, 0.8);
    }

    .eyebrow {
      font-size: 16px;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--orange);
      margin-bottom: 12px;
      opacity: 0;
      animation: fadeUp 0.5s ease 0.1s both;
    }

    h1 {
      font-family: "Advercase", sans-serif;
      font-size: clamp(32px, 8vw, 56px);
      letter-spacing: 3px;
      color: var(--cream);
      margin-bottom: 16px;
      opacity: 0;
      animation: fadeUp 0.5s ease 0.2s both;
    }

    .intro {
      font-size: 16px;
      color: rgba(245, 239, 214, 0.6);
      letter-spacing: 1px;
      line-height: 1.8;
      margin-bottom: 48px;
      opacity: 0;
      animation: fadeUp 0.5s ease 0.3s both;
    }

    .steps {
      list-style: none;
      width: 100%;
      display: flex;
      flex-direction: column;
      gap: 24px;
      margin-bottom: 48px;
      opacity: 0;
      animation: fadeUp 0.5s ease 0.4s both;
    }

    .step {
      display: flex;
      gap: 20px;
      align-items: flex-start;
    }

    .step-number {
      font-family: "Advercase", sans-serif;
      font-size: 32px;
      color: var(--orange);
      line-height: 1;
      flex-shrink: 0;
      width: 32px;
    }

    .step-content {
      padding-top: 4px;
    }

    .step-title {
      font-family: "Space Mono", monospace;
      font-size: 16px;
      color: var(--cream);
      text-transform: uppercase;
      letter-spacing: 2px;
      margin-bottom: 6px;
    }

    .step-desc {
      font-size: 16px;
      color: rgba(245, 239, 214, 0.6);
      line-height: 1.7;
      letter-spacing: 0.5px;
    }

    .step-desc a {
      color: var(--orange);
      text-decoration: none;
      border-bottom: 1px solid rgba(232, 84, 26, 0.4);
      transition: border-color 0.2s;
    }

    .step-desc a:hover {
      border-color: var(--orange);
    }

    .notice {
      width: 100%;
      border: 1px solid rgba(245, 239, 214, 0.1);
      border-left: 3px solid var(--orange);
      padding: 16px 20px;
      margin-bottom: 48px;
      opacity: 0;
      animation: fadeUp 0.5s ease 0.5s both;
    }

    .notice p {
      font-family: "Space Mono", monospace;
      font-size: 16px;
      color: rgba(245, 239, 214, 0.6);
      letter-spacing: 1px;
      line-height: 1.7;
    }

    .notice strong {
      color: var(--cream);
    }

    .cta {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      font-family: "Advercase", sans-serif;
      font-size: 20px;
      letter-spacing: 3px;
      color: var(--black);
      background: var(--mustard);
      text-decoration: none;
      padding: 16px 40px;
      border-radius: 2px;
      transition: all 0.25s;
      position: relative;
      overflow: hidden;
      opacity: 0;
      animation: fadeUp 0.5s ease 0.6s both;
      width: 100%;
      justify-content: center;
    }

    @media (min-width: 480px) {
      .cta {
        width: auto;
      }
    }

    .cta::before {
      content: "";
      position: absolute;
      inset: 0;
      background: var(--orange);
      transform: translateX(-100%);
      transition: transform 0.3s;
    }

    .cta:hover::before {
      transform: translateX(0);
    }

    .cta span {
      position: relative;
      z-index: 1;
    }
  </style>

  <main id="main-content">
    <a href="/" class="back-link">← Terug</a>

    <p class="eyebrow">Last.fm instellen</p>
    <h1>Hoe het werkt</h1>
    <p class="intro">Last.fm houdt bij wat je luistert en deelt dat met Matcher. Volg deze stappen om te beginnen.</p>

    <ol class="steps">
      <li class="step">
        <span class="step-number">1</span>
        <div class="step-content">
          <p class="step-title">Maak een Last.fm account aan</p>
          <p class="step-desc">
            Heb je nog geen account? Maak er gratis een aan op
            <a href="https://www.last.fm/join" target="_blank" rel="noopener">last.fm/join</a>.
          </p>
        </div>
      </li>
      <li class="step">
        <span class="step-number">2</span>
        <div class="step-content">
          <p class="step-title">Zet Spotify Scrobbling aan</p>
          <p class="step-desc">
            Ga naar <a href="https://www.last.fm/settings/applications" target="_blank" rel="noopener">Last.fm instellingen → Applications</a>
            en klik op <strong style="color: var(--cream)">Connect</strong> bij "Spotify Scrobbling". Zo weet Last.fm wat je op Spotify luistert.
          </p>
        </div>
      </li>
      <li class="step">
        <span class="step-number">3</span>
        <div class="step-content">
          <p class="step-title">Luister muziek via Spotify</p>
          <p class="step-desc">
            Last.fm registreert elk nummer dat je afspeelt. Na een paar luistersessies heeft Matcher genoeg data om jouw vinyl matches te tonen.
          </p>
        </div>
      </li>
      <li class="step">
        <span class="step-number">4</span>
        <div class="step-content">
          <p class="step-title">Log in met Last.fm</p>
          <p class="step-desc">
            Klik hieronder om in te loggen. Matcher toont dan welke albums van jouw meest beluisterde artiesten beschikbaar zijn op vinyl.
          </p>
        </div>
      </li>
    </ol>

    <div class="notice">
      <p><strong>Let op:</strong> als je scrobbling net hebt aangezet, kan het 1 tot 2 dagen duren voordat er genoeg luistergeschiedenis is om resultaten te tonen. Je kunt alvast inloggen — zodra er data is verschijnen de matches automatisch.</p>
    </div>

    <a href="/api/auth/lastfm-login" class="cta">
      <span>Inloggen met Last.fm</span>
    </a>
  </main>
</Layout>
