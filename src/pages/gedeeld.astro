---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Gedeelde wishlist" description="Bekijk deze gedeelde vinyl wishlist op Matcher.">
  <style is:global>
    .shared-header {
      text-align: center;
      padding: 64px 0 40px;
    }

    .shared-header .page-title {
      margin-bottom: 8px;
    }

    .shared-header .page-subtitle {
      margin-bottom: 32px;
    }

    .shared-cta {
      font-family: "Advercase", sans-serif;
      font-size: 20px;
      letter-spacing: 3px;
      color: var(--black);
      background: var(--mustard);
      text-decoration: none;
      padding: 12px 32px;
      border-radius: 2px;
      display: inline-block;
      transition: background 0.2s;
      border: none;
      cursor: pointer;
    }

    .shared-cta:hover {
      background: var(--orange);
    }

    .album-artist {
      font-size: 16px;
      color: var(--orange);
      text-transform: uppercase;
      letter-spacing: 2px;
      margin-bottom: 4px;
    }

    .save-album-btn {
      background: none;
      border: 1px solid rgba(245, 239, 214, 0.1);
      color: rgba(245, 239, 214, 0.6);
      font-family: "Space Mono", monospace;
      font-size: 16px;
      letter-spacing: 1px;
      text-transform: uppercase;
      padding: 4px 10px;
      border-radius: 2px;
      cursor: pointer;
      transition: all 0.2s;
      width: 100%;
    }

    .save-album-btn:hover,
    .save-album-btn.saved {
      color: var(--pink);
      border-color: var(--pink);
    }

    .save-album-btn.saved {
      cursor: default;
    }

    .save-toast {
      position: fixed;
      bottom: 24px;
      left: 50%;
      transform: translateX(-50%) translateY(80px);
      background: var(--mustard);
      color: var(--black);
      font-family: "Space Mono", monospace;
      font-size: 16px;
      letter-spacing: 1px;
      padding: 12px 24px;
      border-radius: 2px;
      z-index: 100;
      transition: transform 0.3s ease;
      white-space: nowrap;
      pointer-events: none;
    }

    .save-toast.show {
      transform: translateX(-50%) translateY(0);
    }

    .error-page {
      text-align: center;
      padding: 80px 0;
    }

    .error-page p {
      font-size: 16px;
      color: rgba(245, 239, 214, 0.6);
      letter-spacing: 2px;
      text-transform: uppercase;
      margin-bottom: 24px;
    }

    .vinyl-list {
      margin-bottom: 12px;
    }

    .no-vinyl {
      margin-bottom: 12px;
    }

    .album-card {
      animation: fadeUp 0.4s ease both;
    }
  </style>

  <header class="site-header">
    <div class="wrapper">
      <div class="header-inner">
        <a href="/" class="logo">MATCH<span>ER</span></a>
        <a href="/dashboard" class="back-btn">← Mijn matches</a>
      </div>
    </div>
  </header>

  <main class="wrapper content-wrapper" id="main-content">
    <div id="shared-content"></div>
  </main>

  <script>
    import { getWishlist, saveWishlist } from "../lib/wishlist.js";

    function fromBase64(str: string): string {
      return decodeURIComponent(
        Array.from(atob(str))
          .map((c) => "%" + c.charCodeAt(0).toString(16).padStart(2, "0"))
          .join(""),
      );
    }

    let toastTimer: ReturnType<typeof setTimeout>;
    function showToast(msg: string) {
      let toast = document.getElementById("save-toast") as HTMLElement;
      if (!toast) {
        toast = document.createElement("div");
        toast.id = "save-toast";
        toast.className = "save-toast";
        toast.setAttribute("role", "status");
        toast.setAttribute("aria-live", "polite");
        document.body.appendChild(toast);
      }
      toast.textContent = msg;
      clearTimeout(toastTimer);
      toast.classList.add("show");
      toastTimer = setTimeout(() => toast.classList.remove("show"), 2500);
    }

    function updateSaveButtons() {
      const saved = getWishlist().map((a: any) => a.id);
      document.querySelectorAll<HTMLButtonElement>(".save-album-btn").forEach((btn) => {
        const isSaved = saved.includes(btn.dataset.id!);
        btn.classList.toggle("saved", isSaved);
        btn.textContent = isSaved ? "Opgeslagen ♥" : "Opslaan in wishlist";
        btn.disabled = isSaved;
      });
    }

    const container = document.getElementById("shared-content")!;
    const params = new URLSearchParams(location.search);
    const encoded = params.get("data");

    if (!encoded) {
      container.innerHTML = `
        <div class="error-page">
          <p>Geen wishlist gevonden in de link</p>
          <a href="/" class="shared-cta">Ga naar Matcher</a>
        </div>`;
    } else {
      try {
        const albums: any[] = JSON.parse(fromBase64(encoded));
        if (!Array.isArray(albums) || albums.length === 0) throw new Error("empty");

        let html = `
          <div class="shared-header">
            <h1 class="page-title"><span aria-hidden="true">♡ </span>Gedeelde wishlist</h1>
            <p class="page-subtitle">${albums.length} album${albums.length !== 1 ? "s" : ""}</p>
            <button class="shared-cta" id="save-all-btn">Alles opslaan in mijn wishlist</button>
          </div>
          <ul class="albums-grid">`;

        albums.forEach((album: any, i: number) => {
          html += `
            <li><article class="album-card" style="animation-delay:${i * 0.05}s">
              <div class="album-cover">
                ${
                  album.image
                    ? `<img src="${album.image}" alt="${album.name}" width="640" height="640" loading="lazy" />`
                    : `<div class="album-cover-placeholder"><span>LP</span></div>`
                }
              </div>
              <div class="album-info">
                <p class="album-artist">${album.artist}</p>
                <p class="album-name">${album.name}</p>
                <p class="album-year">${album.releaseYear ?? ""}</p>
                ${
                  album.vinyl && album.vinyl.length > 0
                    ? `<ul class="vinyl-list">${album.vinyl
                        .map(
                          (r: any) =>
                            `<li><a href="https://www.discogs.com${r.uri}" target="_blank" rel="noopener">${r.title} (${r.year ?? "onbekend"})</a></li>`,
                        )
                        .join("")}</ul>`
                    : `<p class="no-vinyl">geen vinyl gevonden</p>`
                }
                <button class="save-album-btn" data-id="${album.id}" data-album='${JSON.stringify(album).replace(/'/g, "&#39;")}'>
                  Opslaan in wishlist
                </button>
              </div>
            </article></li>`;
        });

        html += `</ul>`;
        container.innerHTML = html;

        updateSaveButtons();

        document.addEventListener("click", (e) => {
          const btn = (e.target as Element).closest<HTMLButtonElement>(".save-album-btn");
          if (btn && !btn.disabled) {
            const album = JSON.parse(btn.dataset.album!);
            const wishlist = getWishlist();
            if (!wishlist.find((a: any) => a.id === album.id)) {
              wishlist.push(album);
              saveWishlist(wishlist);
            }
            updateSaveButtons();
            showToast("Opgeslagen in jouw wishlist ♥");
          }

          if ((e.target as Element).id === "save-all-btn") {
            const wishlist = getWishlist();
            let added = 0;
            albums.forEach((album) => {
              if (!wishlist.find((a: any) => a.id === album.id)) {
                wishlist.push(album);
                added++;
              }
            });
            saveWishlist(wishlist);
            updateSaveButtons();
            showToast(added > 0 ? `${added} album${added !== 1 ? "s" : ""} opgeslagen ♥` : "Alles al opgeslagen");
          }
        });
      } catch {
        container.innerHTML = `
          <div class="error-page">
            <p>Ongeldige of verlopen wishlist-link</p>
            <a href="/" class="shared-cta">Ga naar Matcher</a>
          </div>`;
      }
    }
  </script>
</Layout>
