---
import Layout from "../layouts/Layout.astro";
import { getValidToken } from "../lib/spotifyAuth.js";

const accessToken = await getValidToken(Astro.cookies);
if (!accessToken) return Astro.redirect("/");
---

<Layout title="Wishlist" description="Jouw opgeslagen vinyl albums op Matcher.">
  <style is:global>
    .empty-state {
      text-align: center;
      padding: 80px 0;
    }

    .empty-icon {
      font-size: 64px;
      display: block;
      margin-bottom: 24px;
      opacity: 0.3;
    }

    .empty-state p {
      font-size: 16px;
      color: rgba(245, 239, 214, 0.6);
      letter-spacing: 2px;
      text-transform: uppercase;
      margin-bottom: 24px;
    }

    .empty-state a {
      font-family: "Advercase", sans-serif;
      font-size: 20px;
      letter-spacing: 3px;
      color: var(--black);
      background: var(--mustard);
      text-decoration: none;
      padding: 12px 32px;
      border-radius: 2px;
      display: inline-block;
      transition: background 0.2s;
    }

    .empty-state a:hover {
      background: var(--orange);
    }

    .album-card {
      animation: fadeUp 0.4s ease both;
    }

    .album-artist {
      font-size: 16px;
      color: var(--orange);
      text-transform: uppercase;
      letter-spacing: 2px;
      margin-bottom: 4px;
    }

    .vinyl-list {
      margin-bottom: 12px;
    }

    .no-vinyl {
      margin-bottom: 12px;
    }

    .remove-btn {
      background: none;
      border: 1px solid rgba(245, 239, 214, 0.1);
      color: rgba(245, 239, 214, 0.6);
      font-family: "Space Mono", monospace;
      font-size: 16px;
      letter-spacing: 1px;
      text-transform: uppercase;
      padding: 4px 10px;
      border-radius: 2px;
      cursor: pointer;
      transition: all 0.2s;
      width: 100%;
    }

    .remove-btn:hover {
      color: var(--pink);
      border-color: var(--pink);
    }

    .wishlist-title-row {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 16px;
      margin-bottom: 0;
    }

    @media (min-width: 768px) {
      .wishlist-title-row {
        align-items: flex-end;
      }
    }

    .export-btn {
      font-family: "Space Mono", monospace;
      font-size: 16px;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: rgba(245, 239, 214, 0.6);
      background: none;
      border: 1px solid rgba(245, 239, 214, 0.15);
      border-radius: 2px;
      padding: 8px 12px;
      cursor: pointer;
      transition: all 0.2s;
      white-space: nowrap;
      flex-shrink: 0;
    }

    @media (min-width: 768px) {
      .export-btn {
        padding: 10px 20px;
        letter-spacing: 2px;
        margin-bottom: 6px;
      }
    }

    .export-btn:hover {
      color: var(--mustard);
      border-color: var(--mustard);
    }

    .wishlist-actions {
      display: flex;
      flex-direction: column;
      gap: 8px;
      flex-shrink: 0;
      align-items: stretch;
    }

    @media (min-width: 640px) {
      .wishlist-actions {
        flex-direction: row;
        align-items: flex-start;
      }
    }

    .share-toast {
      position: fixed;
      bottom: 24px;
      left: 50%;
      transform: translateX(-50%) translateY(80px);
      background: var(--mustard);
      color: var(--black);
      font-family: "Space Mono", monospace;
      font-size: 16px;
      letter-spacing: 1px;
      padding: 12px 24px;
      border-radius: 2px;
      z-index: 100;
      transition: transform 0.3s ease;
      white-space: nowrap;
      pointer-events: none;
    }

    .share-toast.show {
      transform: translateX(-50%) translateY(0);
    }
  </style>

  <header class="site-header">
    <div class="wrapper">
      <div class="header-inner">
        <a href="/dashboard" class="logo">MATCH<span>ER</span></a>
        <a href="/dashboard" class="back-btn">← Terug</a>
      </div>
    </div>
  </header>

  <main class="wrapper content-wrapper" id="main-content">
    <div class="wishlist-title-row">
      <div>
        <h1 class="page-title"><span aria-hidden="true">♡ </span>Wishlist</h1>
        <p class="page-subtitle" id="wishlist-subtitle">Laden...</p>
      </div>
      <div class="wishlist-actions">
        <button class="export-btn" id="share-btn" hidden>
          <span aria-hidden="true">↗ </span>Delen
        </button>
        <button class="export-btn" id="export-btn" hidden>
          <span aria-hidden="true">↓ </span>Exporteer
        </button>
      </div>
    </div>
    <noscript>
      <p class="noscript-msg">JavaScript is vereist om je wishlist te tonen. Schakel JavaScript in om door te gaan.</p>
    </noscript>
    <div id="wishlist-container"></div>
  </main>

  <script>
    let wishlist: any[] = [];

    async function loadWishlist() {
      try {
        const res = await fetch("/api/wishlist");
        if (res.ok) wishlist = await res.json();
      } catch {}
      renderWishlist();
    }

    function removeFromWishlist(id: string) {
      wishlist = wishlist.filter((a: any) => a.id !== id);
      fetch(`/api/wishlist?id=${id}`, { method: "DELETE" }).catch(() => loadWishlist());
      renderWishlist();
    }

    function exportWishlist() {
      if (wishlist.length === 0) return;

      const rows: string[][] = [["Artiest", "Album", "Jaar", "Discogs links"]];
      wishlist.forEach((album: any) => {
        const links = album.vinyl?.map((r: any) => `https://www.discogs.com${r.uri}`).join(" | ") ?? "";
        rows.push([album.artist, album.name, String(album.releaseYear ?? ""), links]);
      });

      const csv = rows.map((r) => r.map((v) => `"${v.replace(/"/g, '""')}"`).join(",")).join("\n");
      const blob = new Blob([csv], { type: "text/csv;charset=utf-8;" });
      const url = URL.createObjectURL(blob);
      const a = document.createElement("a");
      a.href = url;
      a.download = "matcher-wishlist.csv";
      a.click();
      URL.revokeObjectURL(url);
    }

    document.getElementById("export-btn")!.addEventListener("click", exportWishlist);

    function shareWishlist() {
      if (wishlist.length === 0) return;
      const payload = JSON.stringify(wishlist);
      const encoded = btoa(encodeURIComponent(payload).replace(/%([0-9A-F]{2})/gi, (_, p1) => String.fromCharCode(parseInt(p1, 16))));
      const url = `${location.origin}/gedeeld?data=${encoded}`;
      navigator.clipboard.writeText(url).then(() => {
        showShareToast("Link gekopieerd!");
      }).catch(() => {
        prompt("Kopieer deze link:", url);
      });
    }

    function showShareToast(msg: string) {
      let toast = document.getElementById("share-toast") as HTMLElement;
      if (!toast) {
        toast = document.createElement("div");
        toast.id = "share-toast";
        toast.className = "share-toast";
        toast.setAttribute("role", "status");
        toast.setAttribute("aria-live", "polite");
        document.body.appendChild(toast);
      }
      toast.textContent = msg;
      toast.classList.add("show");
      setTimeout(() => toast.classList.remove("show"), 2500);
    }

    document.getElementById("share-btn")!.addEventListener("click", shareWishlist);

    function renderWishlist() {
      const container = document.getElementById("wishlist-container")!;
      const subtitle = document.getElementById("wishlist-subtitle")!;
      const exportBtn = document.getElementById("export-btn") as HTMLButtonElement;

      subtitle.textContent = `${wishlist.length} album${wishlist.length !== 1 ? "s" : ""} opgeslagen`;
      exportBtn.hidden = wishlist.length === 0;
      (document.getElementById("share-btn") as HTMLButtonElement).hidden = wishlist.length === 0;

      if (wishlist.length === 0) {
        container.innerHTML = `
          <div class="empty-state">
            <span class="empty-icon">♡</span>
            <p>Je wishlist is leeg</p>
            <a href="/dashboard">Ga terug naar matches</a>
          </div>
        `;
        return;
      }

      let html = '<ul class="albums-grid">';

      wishlist.forEach((album: any, i: number) => {
        html += `
          <li><article class="album-card" style="animation-delay: ${i * 0.05}s">
            <div class="album-cover">
              ${
                album.image
                  ? `<img src="${album.image}" alt="${album.name}" width="640" height="640" loading="lazy" />`
                  : `<div class="album-cover-placeholder"><span>LP</span></div>`
              }
            </div>
            <div class="album-info">
              <p class="album-artist">${album.artist}</p>
              <p class="album-name">${album.name}</p>
              <p class="album-year">${album.releaseYear ?? ""}</p>
              ${
                album.vinyl && album.vinyl.length > 0
                  ? `<ul class="vinyl-list">${album.vinyl
                      .map(
                        (r: any) =>
                          `<li><a href="https://www.discogs.com${r.uri}" target="_blank" rel="noopener">${r.title} (${r.year ?? "onbekend"})</a></li>`,
                      )
                      .join("")}</ul>`
                  : `<p class="no-vinyl">geen vinyl gevonden</p>`
              }
              <button class="remove-btn" data-id="${album.id}" aria-label="Verwijderen: ${album.name}">Verwijderen</button>
            </div>
          </article></li>
        `;
      });

      html += "</ul>";
      container.innerHTML = html;

      container.querySelectorAll(".remove-btn").forEach((btn) => {
        btn.addEventListener("click", () => {
          removeFromWishlist((btn as HTMLElement).dataset.id!);
        });
      });
    }

    loadWishlist();
  </script>
</Layout>
