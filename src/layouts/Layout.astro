---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  ogType?: "website" | "article";
}

const {
  title = "Matcher",
  description = "Koppel je Spotify account en ontdek welke albums uit jouw luistergeschiedenis beschikbaar zijn op vinyl via Discogs.",
  ogType = "website",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin);
const fullTitle = title === "Matcher" ? title : `${title} — Matcher`;
---

<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="192x192" href="/icon-192.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="Matcher" />
    <meta property="og:locale" content="nl_NL" />
    <meta property="og:image" content={new URL("/og-image.png", Astro.site ?? Astro.url.origin).toString()} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Matcher — Jouw vinyl matches" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL("/og-image.png", Astro.site ?? Astro.url.origin).toString()} />

    <link rel="preload" href="/fonts/advercase-bold.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/advercase-regular.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/SpaceMono400.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preconnect" href="https://i.scdn.co" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#e8541a" />
    <slot name="head" />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Ga naar inhoud</a>
    <div class="bg-circle"></div>
    <div class="bg-circle"></div>
    <div class="bg-circle"></div>
    <slot />
    <footer class="site-footer">
      <div class="wrapper footer-inner">
        <a href="https://avek.dev" target="_blank" rel="noopener" class="footer-credit">Gemaakt door avek.dev</a>
        <nav class="footer-links" aria-label="Footer navigatie">
          <a href="mailto:contact@avek.dev">Contact</a>
          <a href="/privacy">Privacy</a>
        </nav>
      </div>
    </footer>
  </body>
</html>
