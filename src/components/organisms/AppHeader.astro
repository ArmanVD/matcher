---
import Logo from "../atoms/Logo.astro";
import UserInfo from "../molecules/UserInfo.astro";

interface Props {
  user: { name: string; image?: string | null };
}
const { user } = Astro.props;
---
<style is:global>
  .app-header .logo::after {
    content: "●";
    font-size: 16px;
    color: var(--orange);
    position: absolute;
    top: 8px;
    right: -16px;
    animation: blink 1.5s step-end infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }
</style>

<header class="site-header app-header">
  <div class="wrapper">
    <div class="header-inner">
      <Logo />
      <UserInfo name={user.name} image={user.image} />
    </div>
  </div>
</header>
